{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "migrations/**/*", "scripts/**/*", "knexfile.ts"]
}
